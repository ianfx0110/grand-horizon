<%- include('partials/header') %>

<main>
    <div class="animate">
        <p style="text-transform: uppercase; letter-spacing: 2px; color: var(--accent); font-size: 0.7rem; font-weight: 600; margin-bottom: 0.5rem;">System Intelligence</p>
        <h1>Resource Registry</h1>
        <p style="color: var(--text-dim); max-width: 600px; margin-bottom: 3rem;">Manually provision system identities and operational assets.</p>
    </div>

    <div class="grid mt-8">
        <!-- New User Section -->
        <div class="card animate" style="transition-delay: 0.1s">
            <h2 style="margin-bottom: 2.5rem;">Provision Identity</h2>
            <form action="/admin/create-user" method="POST">
                <div class="form-group">
                    <label>Internal Profile Identity</label>
                    <input type="text" name="username" required placeholder="User identifier">
                </div>
                <div class="form-group">
                    <label>Security Access Protocol (Password)</label>
                    <input type="password" name="password" required placeholder="••••••••">
                </div>
                <div class="form-group">
                    <label>Authorization Level</label>
                    <select name="role">
                        <option value="booker">Elite Booker</option>
                        <option value="staff">Operational Staff</option>
                        <option value="admin">System Admin</option>
                    </select>
                </div>
                <button type="submit" style="width: 100%; margin-top: 2rem;">Authorize Identity</button>
            </form>
        </div>

        <!-- New Room Section -->
        <div class="card animate" style="transition-delay: 0.2s">
            <h2 style="margin-bottom: 2.5rem;">Commission Asset</h2>
            <form action="/admin/create-room" method="POST">
                <div class="form-group">
                    <label>Asset ID (Room Number)</label>
                    <input type="text" name="number" required placeholder="e.g. 305">
                </div>
                <div class="form-group">
                    <label>Classification Architecture</label>
                    <select name="type">
                        <option value="Single">Elite Single</option>
                        <option value="Double">Royal Double</option>
                        <option value="Suite">Savanna Suite</option>
                        <option value="Deluxe">Horizon Deluxe</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Nightly Valuation (USD)</label>
                    <input type="number" name="price" required placeholder="350">
                </div>
                <button type="submit" style="width: 100%; margin-top: 2rem;">Deploy Asset</button>
            </form>
        </div>
    </div>

    <% if (typeof message !== 'undefined') { %>
        <div id="flash-message" style="position: fixed; bottom: 2rem; right: 2rem; background: var(--success); padding: 1rem 2rem; border-radius: 4px; color: white; animation: slideUp 0.5s ease;">
            <%= message %>
        </div>
        <script>
            setTimeout(() => {
                document.getElementById('flash-message').style.display = 'none';
            }, 5000);
        </script>
    <% } %>
</main>

<%- include('partials/footer') %>
