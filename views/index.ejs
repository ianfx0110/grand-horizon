<%- include('partials/header') %>

    <div class="hero">
        <div class="animate">
            <p style="text-transform: uppercase; letter-spacing: 4px; font-weight: 600; font-size: 0.7rem; margin-bottom: 2rem; color: var(--accent);">Established 2026 • Grand Opening</p>
            <h1>Where the Savanna<br>Meets the Stars</h1>
            <p>Experience Grand Horizon: A state-of-the-art sanctuary of Kenyan hospitality, unveiled this year for the modern soul.</p>
            <div style="margin-top: 3.5rem; display: flex; gap: 2rem; justify-content: center;">
                <a href="/signup" class="btn-primary">Reserve Your Stay</a>
                <a href="#heritage" class="secondary" style="padding: 1rem 2.5rem; border: 1px solid var(--accent); color: var(--accent); border-radius: 4px; text-transform: uppercase; font-size: 0.8rem; font-weight: 700; letter-spacing: 2px; text-decoration: none;">Our Story</a>
            </div>
        </div>
    </div>

    <main style="padding: 0; max-width: 100%;">
        <!-- Heritage Section -->
        <section id="heritage" style="padding: 12rem 2rem; background-color: var(--bg-deep);">
            <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 8rem; align-items: center;">
                <div class="animate">
                    <h4 style="color: var(--accent); margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 3px; font-size: 0.8rem; font-weight: 600;">The Horizon Legacy</h4>
                    <h2 style="font-size: 4rem; margin-bottom: 2.5rem; line-height: 1.1;">A Rhythm of<br>the Horizon</h2>
                    <p style="color: var(--text-dim); font-size: 1.15rem; line-height: 2.2; margin-bottom: 4rem;">Unveiled in the dawn of 2026, Grand Horizon was built on a bold promise: to honor the vast, untamed beauty of Kenya with the highest standards of modern grace. We begin our journey today, blending the earth-toned traditions of the Maasai with the crisp, silent luxury of future-forward design.</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;">
                        <div>
                            <h3 style="font-size: 3rem; color: var(--accent); margin-bottom: 0.5rem;">2026</h3>
                            <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; color: var(--text-dim); font-weight: 600;">Year of Opening</p>
                        </div>
                        <div>
                            <h3 style="font-size: 3rem; color: var(--accent); margin-bottom: 0.5rem;">New</h3>
                            <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; color: var(--text-dim); font-weight: 600;">Guest Chapters</p>
                        </div>
                    </div>
                </div>
                <div style="position: relative;" class="animate">
                    <div style="position: absolute; width: 100%; height: 100%; border: 1px solid var(--accent); top: 40px; left: 40px; z-index: 0; opacity: 0.3;"></div>
                    <img src="https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?auto=format&fit=crop&q=80&w=800" alt="Safari Heritage" style="width: 100%; display: block; position: relative; z-index: 1; border-radius: 4px; box-shadow: var(--shadow);">
                </div>
            </div>
        </section>

        <!-- Promotion Banner -->
        <section style="padding: 10rem 2rem; background: linear-gradient(rgba(188, 108, 37, 0.05), transparent);">
            <div style="max-width: 1100px; margin: 0 auto; text-align: center; border: 1px solid var(--border); padding: 7rem 3rem; position: relative; background: var(--bg-card); box-shadow: var(--shadow);">
                <div style="position: absolute; top: -15px; left: 50%; transform: translateX(-50%); background: var(--accent); padding: 0.4rem 2rem; color: var(--bg-deep); text-transform: uppercase; letter-spacing: 4px; font-size: 0.75rem; font-weight: 700; border-radius: 100px;">Exclusive 2026 Privilege</div>
                <h2 style="font-size: 4rem; margin-bottom: 2.5rem;">The Madaraka Season</h2>
                <p style="color: var(--text-dim); font-size: 1.3rem; margin-bottom: 4rem; max-width: 750px; margin-left: auto; margin-right: auto; line-height: 1.8;">Celebrate Kenya's heritage with an extraordinary retreat. Enjoy a <strong>40% privilege discount</strong> on all highland stays throughout the month of June.</p>
                <a href="/signup" class="btn-primary" style="padding: 1.2rem 3.5rem;">Secure My Privilege</a>
            </div>
        </section>
    </main>

<%- include('partials/footer') %>
