<%- include('partials/header') %>

<div class="signup-card" style="max-width: 600px;">
    <a href="/students" class="back-button" title="Back to Registry">✕</a>
    <h2 style="text-align: center; margin-bottom: 2rem; color: var(--accent);">Enroll New Student</h2>
    
    <form action="/newstudent" method="POST">
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="id" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Student ID (Number)</label>
            <input type="number" name="id" id="id" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="fullname" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Full Name</label>
            <input type="text" name="fullname" id="fullname" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="email" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Email Address</label>
            <input type="email" name="email" id="email" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="password" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Password</label>
            <input type="password" name="password" id="password" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <div class="form-group" style="margin-bottom: 2rem;">
            <label for="phone" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Phone Number</label>
            <input type="text" name="phone" id="phone" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <button type="submit" class="btn-primary" style="width: 100%; padding: 1rem; font-weight: bold; font-size: 1rem;">Register Student</button>
    </form>
</div>

<%- include('partials/footer') %>
