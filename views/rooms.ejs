<%- include('partials/header') %>

<main>
    <div class="animate flex justify-between align-center">
        <div>
            <p style="text-transform: uppercase; letter-spacing: 2px; color: var(--accent); font-size: 0.7rem; font-weight: 600; margin-bottom: 0.5rem;">Inventory Control</p>
            <h1>Room Management</h1>
        </div>
        <button id="add-room-btn">Commission New Asset</button>
    </div>

    <div class="grid mt-8" id="rooms-grid">
        <!-- Loaded via JS -->
    </div>
</main>

<!-- Add Room Modal -->
<div id="room-modal" class="modal">
    <div class="modal-content animate">
        <h2>Commission Asset</h2>
        <form id="room-form">
            <div class="form-group">
                <label>Asset ID (Room Number)</label>
                <input type="text" id="room-number" required>
            </div>
            <div class="form-group">
                <label>Classification Architecture</label>
                <select id="room-type">
                    <option value="Single">Elite Single</option>
                    <option value="Double">Royal Double</option>
                    <option value="Suite">Savanna Suite</option>
                    <option value="Deluxe">Horizon Deluxe</option>
                </select>
            </div>
            <div class="form-group">
                <label>Nightly Valuation (USD)</label>
                <input type="number" id="room-price" required>
            </div>
            <div class="flex gap-4" style="margin-top: 2rem;">
                <button type="submit">Deploy Asset</button>
                <button type="button" class="secondary" id="close-modal">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async () => {
        const grid = document.getElementById('rooms-grid');
        const modal = document.getElementById('room-modal');
        
        const loadRooms = async () => {
            const rooms = await api.getRooms();
            grid.innerHTML = '';
            rooms.forEach(room => {
                const card = document.createElement('div');
                card.className = 'card animate';
                card.innerHTML = `
                    <div class="flex justify-between align-start" style="margin-bottom: 1.5rem">
                        <span class="status-tag status-${room.status.toLowerCase()}">${room.status}</span>
                        <div style="font-size: 1.2rem; font-weight: 700; color: var(--accent)">$${room.price}</div>
                    </div>
                    <h3 style="margin-bottom: 0.5rem">Room ${room.number}</h3>
                    <p style="font-size: 0.8rem; color: var(--text-dim); margin-bottom: 2rem;">${room.type}</p>
                    <div class="flex gap-2">
                        <button onclick="handleDelete(${room.id})" class="error-btn" style="flex:1">Decommission</button>
                    </div>
                `;
                grid.appendChild(card);
            });
        };

        window.handleDelete = async (id) => {
            if (confirm('Are you sure you want to decommission this asset?')) {
                await api.deleteRoom(id);
                loadRooms();
            }
        };

        document.getElementById('add-room-btn').onclick = () => modal.classList.add('active');
        document.getElementById('close-modal').onclick = () => modal.classList.remove('active');

        document.getElementById('room-form').onsubmit = async (e) => {
            e.preventDefault();
            await api.addRoom({
                number: document.getElementById('room-number').value,
                type: document.getElementById('room-type').value,
                price: document.getElementById('room-price').value
            });
            modal.classList.remove('active');
            loadRooms();
        };

        loadRooms();
    });
</script>

<%- include('partials/footer') %>
