<%- include('partials/header') %>

<div class="signup-card" style="max-width: 600px;">
    <a href="/courses" class="back-button" title="Back to Courses">✕</a>
    <h2 style="text-align: center; margin-bottom: 2rem; color: var(--accent);">Launch New Course</h2>
    
    <form action="/newcourse" method="POST">
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="id" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Course ID (Number)</label>
            <input type="number" name="id" id="id" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="coursename" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Course Name</label>
            <input type="text" name="coursename" id="coursename" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="description" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Course Description</label>
            <textarea name="description" id="description" rows="3" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;"></textarea>
        </div>
        
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="lecturer" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Lecturer</label>
            <input type="text" name="lecturer" id="lecturer" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <div class="form-group" style="margin-bottom: 2rem;">
            <label for="duration" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Duration (Months)</label>
            <input type="number" name="duration" id="duration" required style="width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 4px; color: white;">
        </div>
        
        <button type="submit" class="btn-primary" style="width: 100%; padding: 1rem; font-weight: bold; font-size: 1rem;">Deploy Course</button>
    </form>
</div>

<%- include('partials/footer') %>
