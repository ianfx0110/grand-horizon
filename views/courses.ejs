<%- include('partials/header') %>

<div class="container" style="max-width: 1000px; margin: 4rem auto; padding: 2rem; background: var(--bg-card); border-radius: 12px; border: 1px solid var(--border);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1 style="color: var(--accent); margin: 0;">Academic Catalog</h1>
        <a href="/newcourse" class="btn-primary" style="padding: 0.6rem 1.2rem;">Add New Course</a>
    </div>

    <% if (courses && courses.length > 0) { %>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
            <% courses.forEach(course => { %>
                <div style="padding: 1.5rem; background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 8px;">
                    <h3 style="margin-top: 0; color: var(--accent);"><%= course.course_name %></h3>
                    <p style="font-size: 0.9rem; color: var(--text-dim); min-height: 3rem;"><%= course.course_description %></p>
                    <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.85rem;">
                        <p><strong>Lecturer:</strong> <%= course.lecturer %></p>
                        <p><strong>Duration:</strong> <%= course.duration_in_months %> Months</p>
                        <p><strong>Reference ID:</strong> <%= course.course_id %></p>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div style="text-align: center; padding: 3rem; color: var(--text-dim); background: rgba(255,255,255,0.02); border-radius: 8px;">
            <p>No courses found in the catalog.</p>
            <p style="font-size: 0.9rem;">(Ensure your MySQL database 'Eldohub' is running and the 'Courses' table exists)</p>
        </div>
    <% } %>

    <div style="margin-top: 2rem; text-align: left;">
        <a href="/students" style="color: var(--accent); text-decoration: underline;">Back to Student Registry</a>
    </div>
</div>

<%- include('partials/footer') %>
